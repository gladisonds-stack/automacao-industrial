FUNCTION_BLOCK "EL_7St_Fct"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR 
      EL  : "EL_7St_UDT";
   END_VAR

   VAR_TEMP 
      tmpFalha : Bool;
      TransitionTo : Struct
         StOff : Bool;
         StPreparing : Bool;
         StWaiting : Bool;
         StStarting : Bool;
         StOn : Bool;
         StIdling : Bool;
         StFault : Bool;
      END_STRUCT;
      tmpSireneOk : Bool;
      tmpHabilita : Bool;
      tmpFalhaLube : Bool;
   END_VAR


BEGIN
	// ==============================================================================
	// BLOCO DE CONTROLE: BRITADOR VSI (Ex: Sandvik CV218)
	// ARQUITETURA: Máquina de 7 Estados (ISA-88 Adaptada)
	// PROTEÇÕES INCLUSAS: Pós-lubrificação (Coast-down), Lube Overrun em Falha,
	//                     Intertravamento Incondicional de Saída e Reset Anti-Memória.
	// ==============================================================================
	
	REGION Init
	    // ==========================================================================
	    // 1. SNAPSHOTS (TRAVAMENTO DE ENTRADAS)
	    // Lemos as entradas físicas apenas uma vez no início do ciclo para evitar 
	    // que o estado de um sensor mude no meio do processamento (flicker) e cause
	    // comportamentos imprevisíveis na máquina de estados.
	    // ==========================================================================
	    
	    // Térmicos e Disjuntores (Geral ou Rotor)
	    #tmpFalha := #EL.EnFDispFalha;
	    
	    // Térmico exclusivo da Bomba de Lubrificação (Crítico para o Overrun)
	    #tmpFalhaLube := #EL.EnFDispFalha_BombaOleo;
	    
	    // Status de intertravamento sonoro (Sirene de partida)
	    #tmpSireneOk := "SIRENE_DB".StSireneOk;
	    
	    // Permissivo de Processo (Silos, Correias, Sensores de Vibração/Porta)
	    #tmpHabilita := #EL.EnHabilita;
	END_REGION
	
	// ==============================================================================
	// 2. LIMPEZA DAS FLAGS DE TRANSIÇÃO
	// Garante que nenhuma transição do ciclo anterior fique "presa" na memória,
	// o que causaria um loop infinito no processador (Cycle Time Exceeded).
	// ==============================================================================
	#TransitionTo.StOff := 0;
	#TransitionTo.StPreparing := 0;
	#TransitionTo.StWaiting := 0;
	#TransitionTo.StStarting := 0;
	#TransitionTo.StOn := 0;
	#TransitionTo.StIdling := 0;
	#TransitionTo.StFault := 0;
	
	REPEAT
	    REGION State_Safety_Net
	        // ======================================================================
	        // 3. REDE DE SEGURANÇA (COLD START / RECOVERY)
	        // Se o CLP for reiniciado ou a máquina perder o referencial (todos os
	        // estados em ZERO e nenhuma transição ativa), forçamos o repouso seguro.
	        // ======================================================================
	        IF NOT #EL.StOff AND NOT #EL.StPreparing AND NOT #EL.StWaiting AND
	            NOT #EL.StStarting AND NOT #EL.StOn AND NOT #EL.StIdling AND
	            NOT #EL.StFault AND NOT #TransitionTo.StOff AND
	            NOT #TransitionTo.StPreparing AND NOT #TransitionTo.StWaiting AND
	            NOT #TransitionTo.StStarting AND NOT #TransitionTo.StOn AND
	            NOT #TransitionTo.StIdling AND NOT #TransitionTo.StFault
	        THEN
	            #EL.StOff := 1;
	            #EL.StStep := 0; // 0: Desligado em repouso
	        END_IF;
	    END_REGION
	    
	    REGION StOff
	        // ======================================================================
	        // ESTADO 0: MÁQUINA DESLIGADA E EM REPOUSO
	        // ======================================================================
	        
	        // --- TRANSIÇÃO DE ENTRADA ---
	        // Ao entrar neste estado, garantimos que todos os outros sejam zerados.
	        IF #TransitionTo.StOff THEN
	            #TransitionTo.StOff := 0;
	            #EL.StOff := 1;
	            #EL.StPreparing := 0;
	            #EL.StWaiting := 0;
	            #EL.StStarting := 0;
	            #EL.StOn := 0;
	            #EL.StIdling := 0;
	            #EL.StFault := 0;
            #EL.Diag.TsEntradaEstado := "Sys_DB".CurrentDT;
	            
	            // Prioridade Máxima: Falha de hardware com a máquina parada
	            IF #tmpFalha OR #tmpFalhaLube THEN
	                #EL.StOff := 0;
	                #TransitionTo.StFault := 1;
	                
	                // Comando de Partida recebido da IHM/Botão
	            ELSIF #EL.CmdOn THEN
	                // Só permite iniciar a sequência se a planta der permissão
	                IF #tmpHabilita THEN
	                    #EL.StOff := 0;
	                    #TransitionTo.StPreparing := 1;
	                ELSE
	                    // Bloqueia a partida e avisa o operador o motivo
	                    #EL.StStep := 10; // 10: Partida bloqueada: Falta permissivo
	                END_IF;
	                
	            ELSE
	                // Mantém na IHM apenas as mensagens válidas de porquê a máquina parou.
	                // Se não for um aviso válido (8, 9, 10), assume "0: Desligado em Repouso".
	                IF #EL.StStep <> 8 AND #EL.StStep <> 9 AND #EL.StStep <> 10 THEN
	                    #EL.StStep := 0;
	                END_IF;
	            END_IF;
	        END_IF;
	    END_REGION
	    
	    REGION StPreparing
	        // ======================================================================
	        // ESTADO 1: PREPARAÇÃO (SIRENE E PARTIDA DA BOMBA DE ÓLEO)
	        // ======================================================================
	        
	        // --- TRANSIÇÃO DE ENTRADA ---
	        IF #TransitionTo.StPreparing THEN
	            #TransitionTo.StPreparing := 0;
	            #EL.StPreparing := 1;
	            #EL.StOff := 0;
	            
	            // ?? WATCHDOG GLOBAL DA PREPARAÇÃO
	            #EL.SdaTime := "SIRENE_DB".ParTempoToque + #EL.ParPrepTime;
	            
	            #EL.StStep := 1; // 1: Iniciando sequência...
	            
	            // --- CICLO DO ESTADO ---
	        ELSIF #EL.StPreparing THEN
	            
	            // 1. CAMADA DE PROTEÇÃO (Abortos imediatos)
	            IF #tmpFalha OR #tmpFalhaLube THEN
	                #EL.StPreparing := 0;
	                #TransitionTo.StFault := 1;
	            ELSIF #EL.CmdOff THEN
	                #EL.StStep := 8;
	                #EL.StPreparing := 0;
	                #TransitionTo.StOff := 1;
	            ELSIF NOT #tmpHabilita THEN
	                #EL.StStep := 9;
	                #EL.StPreparing := 0;
	                #TransitionTo.StOff := 1;
	                
	                // 2. CAMADA DE SEQUENCIAMENTO NORMAL E WATCHDOG
	            ELSE
	                // Decrementa o Watchdog Global livremente, cobrindo toda a Fase 1
	                #EL.SdaTime := #EL.SdaTime - "Sys_DB".OutCycleTime;
	                
	                // PASSO A: Aguardando a Sirene de alerta tocar
	                IF NOT #tmpSireneOk THEN
	                    #EL.StStep := 2; // 2: Aguardando status OK da sirene
	                    
	                    // FAIL-FAST A: Se o tempo estourar AQUI, a Sirene travou/falhou
	                    IF #EL.SdaTime <= T#0ms THEN
	                        #EL.StStep := 12; // 12: Falha Watchdog Sirene
	                        #EL.StPreparing := 0;
	                        #TransitionTo.StFault := 1;
	                    END_IF;
	                    
	                    // PASSO B: Sirene terminou, vamos ligar a Lubrificação
	                ELSIF #tmpSireneOk THEN
	                    
	                    // Apenas atualiza o status na IHM (Não recarregamos o timer!)
	                    IF #EL.StStep <> 3 THEN
	                        #EL.StStep := 3; // 3: Sirene OK, partindo Lubrificação
	                    END_IF;
	                    
	                    // FAIL-FAST B: Se o tempo estourar AQUI, a Bomba de Óleo falhou
	                    IF #EL.SdaTime <= T#0ms THEN
	                        #EL.StStep := 13; // 13: Falha Timeout Lubrificação
	                        #EL.StPreparing := 0;
	                        #TransitionTo.StFault := 1;
	                        
	                        // SUCESSO: Pressostato/Fluxostato confirmou pressão de óleo dentro do tempo
	                    ELSIF #EL.EnFLigado THEN
	                        #EL.StPreparing := 0;
	                        #TransitionTo.StWaiting := 1;
	                    END_IF;
	                END_IF;
	            END_IF;
	        END_IF;
	    END_REGION
	    
	    REGION StWaiting
	        // ======================================================================
	        // ESTADO 2: PRÉ-LUBRIFICAÇÃO (TEMPO DE ESPERA OBRIGATÓRIO)
	        // O óleo precisa circular por galerias, filtros e chegar ao mancal 
	        // superior do VSI antes que o Rotor principal possa ser acionado.
	        // ======================================================================
	        
	        // --- TRANSIÇÃO DE ENTRADA ---
	        IF #TransitionTo.StWaiting THEN
	            #TransitionTo.StWaiting := 0;
	            #EL.StWaiting := 1;
	            #EL.StPreparing := 0;
	            
	            // Carrega o tempo obrigatório de pré-lubrificação estipulado pelo fabricante
	            #EL.SdaDelaySda_2 := #EL.ParPreLubeTime;
	            #EL.StStep := 4; // 4: Lubrificação OK, executando pré-lubrificação
            #EL.Diag.TsEntradaEstado := "Sys_DB".CurrentDT;
	            
	            // --- CICLO DO ESTADO ---
	        ELSIF #EL.StWaiting THEN
	            #EL.SdaDelaySda_2 := #EL.SdaDelaySda_2 - "Sys_DB".OutCycleTime;
	            
	            // Se a pressão de óleo cair ou o térmico atuar no meio da contagem, é falha imediata!
	            IF #tmpFalha OR #tmpFalhaLube OR NOT #EL.EnFLigado THEN
	                #EL.StStep := 15; // 15: Perda de Feedback mecânico
	                #EL.StWaiting := 0;
	                #TransitionTo.StFault := 1;
	                
	            ELSIF #EL.CmdOff THEN
	                #EL.StStep := 8;
	                #EL.StWaiting := 0;
	                #TransitionTo.StOff := 1;
	            ELSIF NOT #tmpHabilita THEN
	                #EL.StStep := 9;
	                #EL.StWaiting := 0;
	                #TransitionTo.StOff := 1;
	                
	                // SUCESSO: Tempo de banho de óleo concluído, avança para partir Rotor
	            ELSIF #EL.SdaDelaySda_2 <= T#0ms THEN
	                #EL.StWaiting := 0;
	                #TransitionTo.StStarting := 1;
	            END_IF;
	        END_IF;
	    END_REGION
	    
	    REGION StStarting
	        // ======================================================================
	        // ESTADO 3: PARTIDA DO MOTOR PRINCIPAL (ROTOR VSI)
	        // O mancal está protegido. Damos comando ao inversor/soft-starter.
	        // ======================================================================
	        
	        // --- TRANSIÇÃO DE ENTRADA ---
	        IF #TransitionTo.StStarting THEN
	            #TransitionTo.StStarting := 0;
	            #EL.StStarting := 1;
	            #EL.StWaiting := 0;
	            
	            // Carrega o Watchdog máximo focado 100% no motor principal atracar
	            #EL.SdaTime := #EL.ParSdaTime;
	            #EL.StStep := 5; // 5: Partindo Motor Principal (Rotor VSI)
            #EL.Diag.LogIndex := (#EL.Diag.LogIndex + 1) MOD 5;
            #EL.Diag.StatusLog[#EL.Diag.LogIndex].Status := #EL.StStep;
            #EL.Diag.StatusLog[#EL.Diag.LogIndex].Timestamp := "Sys_DB".CurrentDT;
            #EL.Diag.StatusLog[#EL.Diag.LogIndex].TempoCiclo := "Sys_DB".CurrentDT - #EL.Diag.TsEntradaEstado;
            IF #EL.Diag.LogCount < 5 THEN
                #EL.Diag.LogCount := #EL.Diag.LogCount + 1;
            END_IF;
            #EL.Diag.TsEntradaEstado := "Sys_DB".CurrentDT;
	                #EL.StStarting := 0;
	                #TransitionTo.StFault := 1;
	                
	                // A Bomba de óleo DEVE continuar ligada e confirmada durante a partida do Rotor
	            ELSIF NOT #EL.EnFLigado THEN
	                #EL.StStep := 15;
	                #EL.StStarting := 0;
	                #TransitionTo.StFault := 1;
	                
	            ELSIF #EL.SdaTime <= T#0ms THEN
	                #EL.StStep := 14; // 14: Falha Timeout do Rotor VSI
	                #EL.StStarting := 0;
	                #TransitionTo.StFault := 1;
	                
	                // PROTEÇÃO DE INÉRCIA: Se abortar por comando manual, vai para Pós-Lubrificação!
	            ELSIF #EL.CmdOff THEN
	                #EL.StStep := 8; // 8: Desligado por comando
	                #EL.StStarting := 0;
	                #TransitionTo.StIdling := 1;
	                
	                // PROTEÇÃO DE INÉRCIA: Se abortar por queda de permissivo, vai para Pós-Lubrificação!
	            ELSIF NOT #tmpHabilita THEN
	                #EL.StStep := 9; // 9: Desligado por perder permissivo
	                #EL.StStarting := 0;
	                #TransitionTo.StIdling := 1;
	                
	                // SUCESSO: Contatora de by-pass ou Relé Running do inversor confirmou o giro
	            ELSIF #EL.EnFLigado_2 THEN
	                #EL.StStarting := 0;
	                #TransitionTo.StOn := 1;
	            END_IF;
	        END_IF;
	    END_REGION
	    
	    REGION StOn
	        // ======================================================================
	        // ESTADO 4: MÁQUINA EM OPERAÇÃO NORMAL
	        // Regime produtivo contínuo. Monitoramento de intertravamentos.
	        // ======================================================================
	        
	        // --- TRANSIÇÃO DE ENTRADA ---
	        IF #TransitionTo.StOn THEN
	            #TransitionTo.StOn := 0;
	            #EL.StOn := 1;
	            #EL.StStarting := 0;
	            #EL.StStep := 6; // 6: Em operação normal
	            #EL.SdaDelayFalha := #EL.ParSdaDelayFalha;
            #EL.Diag.LogIndex := (#EL.Diag.LogIndex + 1) MOD 5;
            #EL.Diag.StatusLog[#EL.Diag.LogIndex].Status := #EL.StStep;
            #EL.Diag.StatusLog[#EL.Diag.LogIndex].Timestamp := "Sys_DB".CurrentDT;
            #EL.Diag.StatusLog[#EL.Diag.LogIndex].TempoCiclo := "Sys_DB".CurrentDT - #EL.Diag.TsEntradaEstado;
            IF #EL.Diag.LogCount < 5 THEN
                #EL.Diag.LogCount := #EL.Diag.LogCount + 1;
            END_IF;
            #EL.Diag.TsEntradaEstado := "Sys_DB".CurrentDT;
	                #EL.StOn := 0;
	                #TransitionTo.StFault := 1;
	                
	                // PROTEÇÃO DE INÉRCIA: Comando de parada manual inicia rampa de parada (Coast-down)
	            ELSIF #EL.CmdOff THEN
	                #EL.StStep := 8; // 8: Desligado por comando
	                #EL.StOn := 0;
	                #TransitionTo.StIdling := 1;
	                
	                // PROTEÇÃO DE INÉRCIA: Queda de permissivo inicia rampa de parada (Coast-down)
	            ELSIF NOT #tmpHabilita THEN
	                #EL.StStep := 9; // 9: Desligado por perder permissivo
	                #EL.StOn := 0;
	                #TransitionTo.StIdling := 1;
	                
	                // MONITORAMENTO: Tolera falhas ultrarrápidas de sensor, mas falha se o delay expirar
	            ELSIF NOT #EL.EnFLigado OR NOT #EL.EnFLigado_2 THEN
	                #EL.SdaDelayFalha := #EL.SdaDelayFalha - "Sys_DB".OutCycleTime;
	                IF #EL.SdaDelayFalha <= T#0ms THEN
	                    #EL.StStep := 15; // 15: Falha Perda de Feedback mecânico
	                    #EL.StOn := 0;
	                    #TransitionTo.StFault := 1;
	                END_IF;
	                
	                // Se os sensores estão OK, mantém o tanque de tolerância cheio
	            ELSIF #EL.EnFLigado AND #EL.EnFLigado_2 THEN
	                #EL.SdaDelayFalha := #EL.ParSdaDelayFalha; // Filtro anti-flicker em ação!
	            END_IF;
	        END_IF;
	    END_REGION
	    
	    REGION StIdling
	        // ======================================================================
	        // ESTADO 5: PARADA POR INÉRCIA (COAST-DOWN / PÓS-LUBRIFICAÇÃO)
	        // O rotor principal já está desenergizado, mas ainda gira por inércia.
	        // A lubrificação é mantida viva para refrigerar o mancal.
	        // ======================================================================
	        
	        // --- TRANSIÇÃO DE ENTRADA ---
	        IF #TransitionTo.StIdling THEN
	            #TransitionTo.StIdling := 0;
	            #EL.StIdling := 1;
	            #EL.StOn := 0;
	            #EL.StStarting := 0;
	            
	            // ?? Carrega o tempo estipulado pela UDT padronizada
	            #EL.SdaTime := #EL.ParSdaDelayIdling;
	            #EL.StStep := 7; // 7: Pós-lubrificação ativa / Inércia
            #EL.Diag.TsEntradaEstado := "Sys_DB".CurrentDT;
	                #EL.StStep := 15; // 15: Falha em Operação: Perda de Feedback mecânico
	                #EL.StIdling := 0;
	                #TransitionTo.StFault := 1;
	                
	                // ---  LÓGICA DE FLYING START ---
	                // Se o processo der condição e o operador apertar LIGA, abortamos a 
	                // parada e voltamos para o início da sequência (tocando a sirene por segurança).
	                // A lubrificação não vai cair durante a sirene graças ao Timer de Overrun!
	            ELSIF #EL.CmdOn AND #tmpHabilita THEN
	                #EL.StIdling := 0;
	                #TransitionTo.StPreparing := 1;
	                
	                // SUCESSO: Rotor está completamente inerte, pode desligar o óleo.
	            ELSIF #EL.SdaTime <= T#0ms THEN
	                // Preserva o status 8 (Desligado Comando) ou 9 (Desligado Permissivo)
	                #EL.StIdling := 0;
	                #TransitionTo.StOff := 1;
	            END_IF;
	        END_IF;
	    END_REGION
	    
	    REGION StFault
	        // ======================================================================
	        // ESTADO 6: FALHA ATIVA (AGUARDANDO AÇÃO DO OPERADOR)
	        // ======================================================================
	        
	        // --- TRANSIÇÃO DE ENTRADA ---
	        IF #TransitionTo.StFault THEN
	            #TransitionTo.StFault := 0;
	            IF NOT #EL.StFault THEN
	                #EL.SdaCntFalha += DINT#1; // Conta +1 no histórico de falhas da máquina
	                #EL.StFault := 1;
	                
	                // Limpa todos os estados operacionais
	                #EL.StOff := 0;
	                #EL.StPreparing := 0;
	                #EL.StWaiting := 0;
	                #EL.StStarting := 0;
	                #EL.StOn := 0;
	                #EL.StIdling := 0;
	                
	                // Protege os status que fornecem detalhes específicos da falha (ex: Timeout, Watchdog)
	                // Se a falha foi genérica (Hardware/Térmico), aplica o código 11.
                #EL.Diag.StatusAnterior := #EL.StStep;
                IF #EL.StStep < 12 OR #EL.StStep > 15 THEN
                    #EL.StStep := 11; // 11: Falha de Segurança/Hardware
                END_IF;
                #EL.Diag.LogIndex := (#EL.Diag.LogIndex + 1) MOD 5;
                #EL.Diag.StatusLog[#EL.Diag.LogIndex].Status := #EL.StStep;
                #EL.Diag.StatusLog[#EL.Diag.LogIndex].Timestamp := "Sys_DB".CurrentDT;
                #EL.Diag.StatusLog[#EL.Diag.LogIndex].TempoCiclo := "Sys_DB".CurrentDT - #EL.Diag.TsEntradaEstado;
                IF #EL.Diag.LogCount < 5 THEN
                    #EL.Diag.LogCount := #EL.Diag.LogCount + 1;
                END_IF;
                #EL.Diag.TsEntradaEstado := "Sys_DB".CurrentDT;
	            END_IF;
	        END_IF;
	    END_REGION
	    
	    // Condição de saída do Loop: Se o bloco for escaneado e não houver nenhuma transição
	    // pendente "voando", ele encerra o processamento dos estados e desce para escrever as saídas.
	UNTIL NOT #TransitionTo.StOn AND NOT #TransitionTo.StOff AND NOT #TransitionTo.StWaiting AND
	    NOT #TransitionTo.StPreparing AND NOT #TransitionTo.StStarting AND
	    NOT #TransitionTo.StIdling AND NOT #TransitionTo.StFault
	END_REPEAT;
	
	REGION Global_End
	    // ==========================================================================
	    // SINALIZAÇÃO VISUAL E LIMPEZA DE COMANDOS
	    // ==========================================================================
	    
	    // Pisca a lâmpada de painel (ou botão de falha da IHM) a 2Hz enquanto aguarda Reset
	    #EL.SdaFalhaReset := #EL.StFault AND "Clock_2Hz";
	    
	    // Zera incondicionalmente os comandos da IHM a cada ciclo de scan.
	    // Isso garante que os botões ajam como "pulsos" limpos e evita comportamento fantasma.
	    #EL.CmdOn := 0;
	    #EL.CmdOff := 0;
	    #EL.CmdFalhaReset := 0;
	    
	    // ==========================================================================
	    // OVERRUN DE SEGURANÇA (PROTEÇÃO EXTREMA DA LUBRIFICAÇÃO EM CASO DE FALHA)
	    // Se a máquina desarmar com o rotor a 1800 RPM (Ex: Térmico do Rotor atuar e 
	    // forçar a máquina inteira a ir para StFault), a bomba de óleo NÃO PODE parar. 
	    // Ela deve continuar rodando pelo tempo do Coast-down (MemLubeOverrun).
	    // ==========================================================================
	    IF #EL.StStarting OR #EL.StOn OR #EL.StIdling THEN
	        // ?? Mantém o "tanque de tempo" de inércia sempre cheio usando a tag padronizada
	        #EL.StLubeOverrunTime := #EL.ParSdaDelayIdling;
	    ELSE
	        // Se a máquina cair para StFault ou repouso, esvazia o tempo gradativamente
	        #EL.StLubeOverrunTime := #EL.StLubeOverrunTime - "Sys_DB".OutCycleTime;
	        IF #EL.StLubeOverrunTime < T#0ms THEN
	            #EL.StLubeOverrunTime := T#0ms;
	        END_IF;
	    END_IF;
	    
	    // ==========================================================================
	    // ACIONAMENTO DAS SAÍDAS FÍSICAS (MAPEAMENTO DE HARDWARE)
	    // ==========================================================================
	    
	    // MOTOR 1 (Bomba de Lubrificação - VSI Lube Pump)
	    // O Óleo flui em: Partida (pós-sirene), Pré-Lube, Partindo Rotor, Rodando, Parando (Inércia)
	    // E também flui em caso de FALHA DO ROTOR, graças ao Overrun Timer salvador!
	    #EL.SdaF := (
	    #EL.StWaiting OR
	    #EL.StStarting OR
	    #EL.StOn OR
	    #EL.StIdling OR
	    (#EL.StPreparing AND #tmpSireneOk) OR
	    (#EL.StLubeOverrunTime > T#0ms)
	    )
	    AND NOT #tmpFalhaLube; // Apenas a falha térmica da *própria* bomba corta sua energia.
	    
	    // MOTOR 2 (Rotor Principal - VSI Drive Motor)
	    // O Rotor exige o estado correto, permissivos, ausência de falhas gerais/térmicas
	    // E OBRIGATORIAMENTE o acionamento simultâneo da bomba de lubrificação (SdaF).
	    #EL.SdaF_2 := (#EL.StOn OR #EL.StStarting)
	    AND #tmpHabilita
	    AND NOT #tmpFalha
	    AND NOT #EL.StFault
	    AND #EL.SdaF;
	    
	END_REGION
	
	REGION Tabela de referência de Status
	(*
	 =========================================================
	 TABELA DE REFERÊNCIA IHM: STATUS VSI (7 ESTADOS)
	 =========================================================      
	   |ID    |Categoria   |Descrição 
	 ==|======|============|================================= 
	   |0     |Operação    |Desligado em repouso
	   |1     |Operação    |Iniciando sequência...
	   |2     |Operação    |Aguardando status OK da sirene
	   |3     |Operação    |Sirene OK, partindo Lubrificação
	   |4     |Operação    |Lubrificação OK, executando pré-lubrificação
	   |5     |Operação    |Partindo Motor Principal (Rotor VSI)
	   |6     |Operação    |Em operação normal
	   |7     |Operação    |Pós-lubrificação ativa (Desligando motor principal)
	   |8     |Aviso       |Desligado por comando
	   |9     |Aviso       |Desligado por perder permissivo (Habilita)
	   |10    |Aviso       |Partida bloqueada: Falta permissivo (Habilita)
	   |11    |Falha       |Falha de Segurança/Hardware (Térmico/Disjuntor)
	   |12    |Falha       |Falha de Partida: Watchdog da Sirene
	   |13    |Falha       |Falha de Partida: Timeout da Lubrificação
	   |14    |Falha       |Falha de Partida: Timeout do Rotor VSI
	   |15    |Falha       |Falha em Operação: Perda de Feedback mecânico
	 =========================================================
	 *)
	END_REGION
END_FUNCTION_BLOCK

