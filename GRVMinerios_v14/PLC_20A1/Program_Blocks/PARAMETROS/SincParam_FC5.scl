	        IF "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayFalha.TRANSPORTADORES.TRP18 <> "TRANSPORTADORES_DB".TRP18.EL.ParSdaDelayFalha
	            AND "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayFalha.TRANSPORTADORES.TRP18 > T#0ms
	        THEN
	            "TRANSPORTADORES_DB".TRP18.EL.ParSdaDelayFalha := "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayFalha.TRANSPORTADORES.TRP18;
	        END_IF;
	    END_REGION
	    
	    REGION TRP19
	        IF "IHM_DB".Parametros.Tempos_Processo.ParSdaTime.TRANSPORTADORES.TRP19 <> "TRANSPORTADORES_DB".TRP19.EL.ParSdaTime
