	        // ParSdaDelayIdling
	        IF "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayIdling.BRITADORES.BR03 <> "BRITADORES_DB".BRT03.EL.ParSdaDelayIdling
	            AND "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayIdling.BRITADORES.BR03 > T#0ms
	        THEN
	            "BRITADORES_DB".BRT03.EL.ParSdaDelayIdling := "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayIdling.BRITADORES.BR03;
	        END_IF;
	    END_REGION
	    
