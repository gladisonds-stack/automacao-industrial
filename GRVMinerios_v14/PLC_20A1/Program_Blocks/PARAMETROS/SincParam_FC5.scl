	END_REGION
	
	REGION SIRENE
	    
	    // Sincroniza o tempo de toque
	    IF "IHM_DB".Parametros.Sirene.ParTempoToque <> "SIRENE_DB".ParTempoToque
	        AND "IHM_DB".Parametros.Sirene.ParTempoToque > T#0ms
	    THEN
	        "SIRENE_DB".ParTempoToque := "IHM_DB".Parametros.Sirene.ParTempoToque;
	    END_IF;
	    
	    // Sincroniza o tempo de validade
	    IF "IHM_DB".Parametros.Sirene.ParTempoValidade <> "SIRENE_DB".ParTempoValidade
	        AND "IHM_DB".Parametros.Sirene.ParTempoValidade > T#0ms
	    THEN
	        "SIRENE_DB".ParTempoValidade := "IHM_DB".Parametros.Sirene.ParTempoValidade;
	    END_IF;
	    
	    // Sincroniza o acionamento de teste da sirene
	    //IF "IHM_DB".Comandos.CmdTesteSirene <> "SIRENE_DB".CmdTesteManual
