	        IF "IHM_DB".Parametros.Tempos_Processo.ParSdaTime.PENEIRAS.PNR04 <> "PENEIRAS_DB".PNR04.EL.ParSdaTime
	            AND "IHM_DB".Parametros.Tempos_Processo.ParSdaTime.PENEIRAS.PNR04 > T#0ms
	        THEN
