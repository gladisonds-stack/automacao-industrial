	        IF "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayFalha.TRANSPORTADORES.TRP17 <> "TRANSPORTADORES_DB".TRP17.EL.ParSdaDelayFalha
	            AND "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayFalha.TRANSPORTADORES.TRP17 > T#0ms
