FUNCTION "SincParam" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      InpDesabilitaSinc : Bool;
   END_VAR


BEGIN
	// ==============================================================================
	// BLOCO: SincParam
	// FUNÇÃO: Sincronismo IHM <> DBs de Controle por Alteração de Valor
	// ==============================================================================
	
	// Trava de Manutenção/Operação
	IF #InpDesabilitaSinc THEN
	    RETURN; // Aborta a execução se a tag for TRUE
	END_IF;
	
	REGION BRITADORES
	    
	    REGION BR02        
	        // ParPrepTime
	        IF "IHM_DB".Parametros.Tempos_Processo.ParPrepTime.BRITADORES.BR02 <> "BRITADORES_DB".BRT02.EL.ParPrepTime
	            AND "IHM_DB".Parametros.Tempos_Processo.ParPrepTime.BRITADORES.BR02 > T#0ms
	        THEN
	            "BRITADORES_DB".BRT02.EL.ParPrepTime := "IHM_DB".Parametros.Tempos_Processo.ParPrepTime.BRITADORES.BR02;
	        END_IF;
	        
	        // ParSdaTime
	        IF "IHM_DB".Parametros.Tempos_Processo.ParSdaTime.BRITADORES.BR02 <> "BRITADORES_DB".BRT02.EL.ParSdaTime
	            AND "IHM_DB".Parametros.Tempos_Processo.ParSdaTime.BRITADORES.BR02 > T#0ms
	        THEN
	            "BRITADORES_DB".BRT02.EL.ParSdaTime := "IHM_DB".Parametros.Tempos_Processo.ParSdaTime.BRITADORES.BR02;
	        END_IF;
	        
	        // ParSdaDelayFalha
	        IF "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayFalha.BRITADORES.BR02 <> "BRITADORES_DB".BRT02.EL.ParSdaDelayFalha
	            AND "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayFalha.BRITADORES.BR02 > T#0ms
	        THEN
	            "BRITADORES_DB".BRT02.EL.ParSdaDelayFalha := "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayFalha.BRITADORES.BR02;
	        END_IF;
	        
	        // ParSdaDelayIdling
	        IF "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayIdling.BRITADORES.BR02 <> "BRITADORES_DB".BRT02.EL.ParSdaDelayIdling
	            AND "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayIdling.BRITADORES.BR02 > T#0ms
	        THEN
	            "BRITADORES_DB".BRT02.EL.ParSdaDelayIdling := "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayIdling.BRITADORES.BR02;
	        END_IF;
	    END_REGION
	    
	    REGION BR03        
	        // ParPrepTime
	        IF "IHM_DB".Parametros.Tempos_Processo.ParPrepTime.BRITADORES.BR03 <> "BRITADORES_DB".BRT03.EL.ParPrepTime
	            AND "IHM_DB".Parametros.Tempos_Processo.ParPrepTime.BRITADORES.BR03 > T#0ms
