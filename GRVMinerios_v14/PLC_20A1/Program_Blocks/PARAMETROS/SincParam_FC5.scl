	        END_IF;
	        
	        // ParSdaTime
	        IF "IHM_DB".Parametros.Tempos_Processo.ParSdaTime.BRITADORES.BR03 <> "BRITADORES_DB".BRT03.EL.ParSdaTime
	            AND "IHM_DB".Parametros.Tempos_Processo.ParSdaTime.BRITADORES.BR03 > T#0ms
