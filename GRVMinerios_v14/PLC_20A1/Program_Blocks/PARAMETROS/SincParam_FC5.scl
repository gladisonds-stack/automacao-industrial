	        IF "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayFalha.TRANSPORTADORES.TRP16 <> "TRANSPORTADORES_DB".TRP16.EL.ParSdaDelayFalha
	            AND "IHM_DB".Parametros.Tempos_Processo.ParSdaDelayFalha.TRANSPORTADORES.TRP16 > T#0ms
