	        "ACIONA TRANSPORTADOR DE CORREIA 12" := #TRP12.EL.SdaF;
	    END_REGION
	END_REGION
	
	REGION "TRP 13 - SAÍDA PNR03"
	    REGION "1. MAP_IN"
	        #TRP13.EL.StBotao := "LIGA TRANSPORTADOR DE CORREIA 13";
	        #TRP13.EL.CmdFalhaReset := "RESET MESA DE CONTROLE";
	        #TRP13.EL.EnFLigado := "TRANSPORTADOR DE CORREIA 13 LIGADO";
	        #TRP13.EL.EnFDispFalha := "TÉRMICO TRANSPORTADOR DE CORREIA 13";
