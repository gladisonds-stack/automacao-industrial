	        #TRP08.EL.CmdFalhaReset := "RESET MESA DE CONTROLE";
	        #TRP08.EL.EnFLigado := "TRANSPORTADOR DE CORREIA 08 LIGADO";
	        #TRP08.EL.EnFDispFalha := "TÉRMICO TRANSPORTADOR DE CORREIA 08";
	    END_REGION
	    REGION "2. PROCESS"
	        #permissivos_trp08 := "GERAL_EMERGENCIA_OK" AND NOT "CONTROLE_STATUS_DB".StFaultGlobal.BRITADORES.BRT02;
	        #TRP08.EL.EnHabilita := ("SELEÇÃO MANUAL" AND #permissivos_trp08) OR ("SELEÇÃO AUTOMÁTICO" AND #permissivos_trp08 AND "CONTROLE_STATUS_DB".StOnGlobal.PENEIRAS.PNR02);
	        IF #TRP08.EL.StBotao AND NOT #TRP08.EL.StAnteriorBotao THEN
	            IF #TRP08.EL.StOff THEN
	                #TRP08.EL.CmdOn := true;
