	    END_REGION
	END_REGION
	
	// ==============================================================================
	// LINHA C: CIRCUITO BRITADOR VSI 04
	// ==============================================================================
	
	REGION "TRP 14 - SAÍDA BRT04 A"
	    REGION "1. MAP_IN"
	        #TRP14.EL.StBotao := "LIGA TRANSPORTADOR DE CORREIA 14";
	        #TRP14.EL.CmdFalhaReset := "RESET MESA DE CONTROLE";
	        #TRP14.EL.EnFLigado := "TRANSPORTADOR DE CORREIA 14 LIGADO";
	        #TRP14.EL.EnFDispFalha := "TÉRMICO TRANSPORTADOR DE CORREIA 14";
	    END_REGION
	    REGION "2. PROCESS"
	        #permissivos_trp14 := "GERAL_EMERGENCIA_OK" AND NOT "CONTROLE_STATUS_DB".StFaultGlobal.PENEIRAS.PNR04;
	        #TRP14.EL.EnHabilita := ("SELEÇÃO MANUAL" AND #permissivos_trp14) OR ("SELEÇÃO AUTOMÁTICO" AND #permissivos_trp14 AND "CONTROLE_STATUS_DB".StOnGlobal.PENEIRAS.PNR04);
