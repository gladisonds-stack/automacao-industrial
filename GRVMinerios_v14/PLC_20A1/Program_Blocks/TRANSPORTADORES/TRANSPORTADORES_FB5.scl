FUNCTION_BLOCK "TRANSPORTADORES"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR 
      TRP06 { S7_SetPoint := 'False'} : "EL_4St_Fct";
      TRP07 { S7_SetPoint := 'False'} : "EL_4St_Fct";
      TRP08 { S7_SetPoint := 'False'} : "EL_4St_Fct";
      TRP09 { S7_SetPoint := 'False'} : "EL_4St_Fct";
      TRP10 { S7_SetPoint := 'False'} : "EL_4St_Fct";
      TRP11 { S7_SetPoint := 'False'} : "EL_4St_Fct";
      TRP12 { S7_SetPoint := 'False'} : "EL_4St_Fct";
      TRP13 { S7_SetPoint := 'False'} : "EL_4St_Fct";
      TRP14 { S7_SetPoint := 'False'} : "EL_4St_Fct";
      TRP15 { S7_SetPoint := 'False'} : "EL_4St_Fct";
      TRP16 { S7_SetPoint := 'False'} : "EL_4St_Fct";
      TRP17 { S7_SetPoint := 'False'} : "EL_4St_Fct";
      TRP18 { S7_SetPoint := 'False'} : "EL_4St_Fct";
      TRP19 { S7_SetPoint := 'False'} : "EL_4St_Fct";
   END_VAR

   VAR_TEMP 
      permissivos_trp06 : Bool;
      permissivos_trp07 : Bool;
      permissivos_trp08 : Bool;
      permissivos_trp09 : Bool;
      permissivos_trp10 : Bool;
      permissivos_trp11 : Bool;
      permissivos_trp12 : Bool;
      permissivos_trp13 : Bool;
      permissivos_trp14 : Bool;
      permissivos_trp15 : Bool;
      permissivos_trp16 : Bool;
      permissivos_trp17 : Bool;
      permissivos_trp18 : Bool;
      permissivos_trp19 : Bool;
      tmpSelManual : Bool;
   END_VAR


BEGIN
	// ==============================================================================
	// BLOCO: FB5 - GESTÃO DE TRANSPORTADORES DE CORREIA (TRP06 a TRP19)
	// ARQUITETURA: Encapsulamento em Regions (Map_In -> Process -> Core -> Map_Out)
	// ==============================================================================
	
	REGION "CONFIGURAÇÃO GERAL DE OPERAÇÃO"
	    // Sincronização do modo de operação manual/automático
	    #tmpSelManual := "SELEÇÃO MANUAL";
	    
	    #TRP06.EL.EnManual := #tmpSelManual;
	    #TRP07.EL.EnManual := #tmpSelManual;
	    #TRP08.EL.EnManual := #tmpSelManual;
	    #TRP09.EL.EnManual := #tmpSelManual;
	    #TRP10.EL.EnManual := #tmpSelManual;
	    #TRP11.EL.EnManual := #tmpSelManual;
	    #TRP12.EL.EnManual := #tmpSelManual;
	    #TRP13.EL.EnManual := #tmpSelManual;
	    #TRP14.EL.EnManual := #tmpSelManual;
	    #TRP15.EL.EnManual := #tmpSelManual;
	    #TRP16.EL.EnManual := #tmpSelManual;
	    #TRP17.EL.EnManual := #tmpSelManual;
	    #TRP18.EL.EnManual := #tmpSelManual;
	    #TRP19.EL.EnManual := #tmpSelManual;
	END_REGION
	
	// ==============================================================================
	// LINHA A: CIRCUITO BRITADOR CÔNICO 02
	// ==============================================================================
	
	REGION "TRP 06 - ALIMENTAÇÃO BRT02"
	    REGION "1. MAP_IN"
	        #TRP06.EL.StBotao := "LIGA TRANSPORTADOR DE CORREIA 06";
	        #TRP06.EL.CmdFalhaReset := "RESET MESA DE CONTROLE";
	        #TRP06.EL.EnFLigado := "TRANSPORTADOR DE CORREIA 06 LIGADO";
	        #TRP06.EL.EnFDispFalha := "TÉRMICO TRANSPORTADOR DE CORREIA 06";
	    END_REGION
	    REGION "2. PROCESS"
	        #permissivos_trp06 := "GERAL_EMERGENCIA_OK" AND NOT "CONTROLE_STATUS_DB".StFaultGlobal.BRITADORES.BRT02 AND NOT "CONTROLE_STATUS_DB".StFalhaDetectores.DTC01;
	        #TRP06.EL.EnHabilita := ("SELEÇÃO MANUAL" AND #permissivos_trp06) OR ("SELEÇÃO AUTOMÁTICO" AND #permissivos_trp06 AND "CONTROLE_STATUS_DB".StOnGlobal.BRITADORES.BRT02);
	        IF #TRP06.EL.StBotao AND NOT #TRP06.EL.StAnteriorBotao THEN
	            IF #TRP06.EL.StOff THEN
	                #TRP06.EL.CmdOn := true;
	            ELSE
	                #TRP06.EL.CmdOff := true;
	            END_IF;
	        END_IF;
	        #TRP06.EL.StAnteriorBotao := #TRP06.EL.StBotao;
	    END_REGION
	    REGION "3. CORE"
	        #TRP06();
	    END_REGION
	    REGION "4. MAP_OUT"
	        "ACIONA TRANSPORTADOR DE CORREIA 06" := #TRP06.EL.SdaF;
	    END_REGION
	END_REGION
	
	REGION "TRP 07 - SAÍDA BRT02 PARA PNR02"
	    REGION "1. MAP_IN"
	        #TRP07.EL.StBotao := "LIGA TRANSPORTADOR DE CORREIA 07";
	        #TRP07.EL.CmdFalhaReset := "RESET MESA DE CONTROLE";
	        #TRP07.EL.EnFLigado := "TRANSPORTADOR DE CORREIA 07 LIGADO";
	        #TRP07.EL.EnFDispFalha := "TÉRMICO TRANSPORTADOR DE CORREIA 07";
	    END_REGION
	    REGION "2. PROCESS"
	        #permissivos_trp07 := "GERAL_EMERGENCIA_OK" AND NOT "CONTROLE_STATUS_DB".StFaultGlobal.BRITADORES.BRT02 AND NOT "CONTROLE_STATUS_DB".StFaultGlobal.PENEIRAS.PNR02;
	        #TRP07.EL.EnHabilita := ("SELEÇÃO MANUAL" AND #permissivos_trp07) OR ("SELEÇÃO AUTOMÁTICO" AND #permissivos_trp07 AND "CONTROLE_STATUS_DB".StOnGlobal.PENEIRAS.PNR02);
	        IF #TRP07.EL.StBotao AND NOT #TRP07.EL.StAnteriorBotao THEN
	            IF #TRP07.EL.StOff THEN
	                #TRP07.EL.CmdOn := true;
	            ELSE
	                #TRP07.EL.CmdOff := true;
	            END_IF;
	        END_IF;
	        #TRP07.EL.StAnteriorBotao := #TRP07.EL.StBotao;
	    END_REGION
	    REGION "3. CORE"
	        #TRP07();
	    END_REGION
	    REGION "4. MAP_OUT"
	        "ACIONA TRANSPORTADOR DE CORREIA 07" := #TRP07.EL.SdaF;
	    END_REGION
	END_REGION
	
