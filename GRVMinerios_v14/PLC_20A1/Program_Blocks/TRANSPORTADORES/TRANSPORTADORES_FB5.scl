	END_REGION
	
	REGION "TRP 19 - PRODUTO FINAL C"
	    REGION "1. MAP_IN"
	        #TRP19.EL.StBotao := "LIGA TRANSPORTADOR DE CORREIA 19";
	        #TRP19.EL.CmdFalhaReset := "RESET MESA DE CONTROLE";
	        #TRP19.EL.EnFLigado := "TRANSPORTADOR DE CORREIA 19 LIGADO";
	        #TRP19.EL.EnFDispFalha := "TÉRMICO TRANSPORTADOR DE CORREIA 19";
	    END_REGION
	    REGION "2. PROCESS"
	        #permissivos_trp19 := "GERAL_EMERGENCIA_OK" AND NOT "CONTROLE_STATUS_DB".StFaultGlobal.PENEIRAS.PNR04;
	        #TRP19.EL.EnHabilita := ("SELEÇÃO MANUAL" AND #permissivos_trp19) OR ("SELEÇÃO AUTOMÁTICO" AND #permissivos_trp19 AND "CONTROLE_STATUS_DB".StOnGlobal.PENEIRAS.PNR04);
	        IF #TRP19.EL.StBotao AND NOT #TRP19.EL.StAnteriorBotao THEN
	            IF #TRP19.EL.StOff THEN
	                #TRP19.EL.CmdOn := true;
	            ELSE
	                #TRP19.EL.CmdOff := true;
	            END_IF;
	        END_IF;
	        #TRP19.EL.StAnteriorBotao := #TRP19.EL.StBotao;
	    END_REGION
	    REGION "3. CORE"
	        #TRP19();
	    END_REGION
	    REGION "4. MAP_OUT"
	        "ACIONA TRANSPORTADOR DE CORREIA 19" := #TRP19.EL.SdaF;
	    END_REGION
	END_REGION
	
	// ==============================================================================
	// MAPEAMENTO GLOBAL DE STATUS PARA A IHM / SCADA
	// ==============================================================================
	REGION "ESCREVENDO STATUS GERAL"
	    "CONTROLE_STATUS_DB".StSomaFalhas.StFalhaTransportadores := #TRP06.EL.StFault OR
	    #TRP07.EL.StFault OR #TRP08.EL.StFault OR #TRP09.EL.StFault OR #TRP10.EL.StFault OR
	    #TRP11.EL.StFault OR #TRP12.EL.StFault OR #TRP13.EL.StFault OR #TRP14.EL.StFault OR
	    #TRP15.EL.StFault OR #TRP16.EL.StFault OR #TRP17.EL.StFault OR #TRP18.EL.StFault OR
	    #TRP19.EL.StFault;
	    
	    // Status Starting
	    "CONTROLE_STATUS_DB".StStartingGlobal.TRANSPORTADORES.TRP06 := #TRP06.EL.StStarting;
	    "CONTROLE_STATUS_DB".StStartingGlobal.TRANSPORTADORES.TRP07 := #TRP07.EL.StStarting;
	    "CONTROLE_STATUS_DB".StStartingGlobal.TRANSPORTADORES.TRP08 := #TRP08.EL.StStarting;
	    "CONTROLE_STATUS_DB".StStartingGlobal.TRANSPORTADORES.TRP09 := #TRP09.EL.StStarting;
	    "CONTROLE_STATUS_DB".StStartingGlobal.TRANSPORTADORES.TRP10 := #TRP10.EL.StStarting;
	    "CONTROLE_STATUS_DB".StStartingGlobal.TRANSPORTADORES.TRP11 := #TRP11.EL.StStarting;
	    "CONTROLE_STATUS_DB".StStartingGlobal.TRANSPORTADORES.TRP12 := #TRP12.EL.StStarting;
	    "CONTROLE_STATUS_DB".StStartingGlobal.TRANSPORTADORES.TRP13 := #TRP13.EL.StStarting;
	    "CONTROLE_STATUS_DB".StStartingGlobal.TRANSPORTADORES.TRP14 := #TRP14.EL.StStarting;
	    "CONTROLE_STATUS_DB".StStartingGlobal.TRANSPORTADORES.TRP15 := #TRP15.EL.StStarting;
	    "CONTROLE_STATUS_DB".StStartingGlobal.TRANSPORTADORES.TRP16 := #TRP16.EL.StStarting;
	    "CONTROLE_STATUS_DB".StStartingGlobal.TRANSPORTADORES.TRP17 := #TRP17.EL.StStarting;
	    "CONTROLE_STATUS_DB".StStartingGlobal.TRANSPORTADORES.TRP18 := #TRP18.EL.StStarting;
	    "CONTROLE_STATUS_DB".StStartingGlobal.TRANSPORTADORES.TRP19 := #TRP19.EL.StStarting;
	    
	    // Status On/Off
	    "CONTROLE_STATUS_DB".StOnGlobal.TRANSPORTADORES.TRP06 := #TRP06.EL.StOn;
	    "CONTROLE_STATUS_DB".StOnGlobal.TRANSPORTADORES.TRP07 := #TRP07.EL.StOn;
	    "CONTROLE_STATUS_DB".StOnGlobal.TRANSPORTADORES.TRP08 := #TRP08.EL.StOn;
	    "CONTROLE_STATUS_DB".StOnGlobal.TRANSPORTADORES.TRP09 := #TRP09.EL.StOn;
	    "CONTROLE_STATUS_DB".StOnGlobal.TRANSPORTADORES.TRP10 := #TRP10.EL.StOn;
	    "CONTROLE_STATUS_DB".StOnGlobal.TRANSPORTADORES.TRP11 := #TRP11.EL.StOn;
	    "CONTROLE_STATUS_DB".StOnGlobal.TRANSPORTADORES.TRP12 := #TRP12.EL.StOn;
	    "CONTROLE_STATUS_DB".StOnGlobal.TRANSPORTADORES.TRP13 := #TRP13.EL.StOn;
	    "CONTROLE_STATUS_DB".StOnGlobal.TRANSPORTADORES.TRP14 := #TRP14.EL.StOn;
	    "CONTROLE_STATUS_DB".StOnGlobal.TRANSPORTADORES.TRP15 := #TRP15.EL.StOn;
	    "CONTROLE_STATUS_DB".StOnGlobal.TRANSPORTADORES.TRP16 := #TRP16.EL.StOn;
	    "CONTROLE_STATUS_DB".StOnGlobal.TRANSPORTADORES.TRP17 := #TRP17.EL.StOn;
	    "CONTROLE_STATUS_DB".StOnGlobal.TRANSPORTADORES.TRP18 := #TRP18.EL.StOn;
	    "CONTROLE_STATUS_DB".StOnGlobal.TRANSPORTADORES.TRP19 := #TRP19.EL.StOn;
	    
	    // Status Falha
	    "CONTROLE_STATUS_DB".StFaultGlobal.TRANSPORTADORES.TRP06 := #TRP06.EL.StFault;
	    "CONTROLE_STATUS_DB".StFaultGlobal.TRANSPORTADORES.TRP07 := #TRP07.EL.StFault;
	    "CONTROLE_STATUS_DB".StFaultGlobal.TRANSPORTADORES.TRP08 := #TRP08.EL.StFault;
	    "CONTROLE_STATUS_DB".StFaultGlobal.TRANSPORTADORES.TRP09 := #TRP09.EL.StFault;
	    "CONTROLE_STATUS_DB".StFaultGlobal.TRANSPORTADORES.TRP10 := #TRP10.EL.StFault;
	    "CONTROLE_STATUS_DB".StFaultGlobal.TRANSPORTADORES.TRP11 := #TRP11.EL.StFault;
	    "CONTROLE_STATUS_DB".StFaultGlobal.TRANSPORTADORES.TRP12 := #TRP12.EL.StFault;
	    "CONTROLE_STATUS_DB".StFaultGlobal.TRANSPORTADORES.TRP13 := #TRP13.EL.StFault;
	    "CONTROLE_STATUS_DB".StFaultGlobal.TRANSPORTADORES.TRP14 := #TRP14.EL.StFault;
	    "CONTROLE_STATUS_DB".StFaultGlobal.TRANSPORTADORES.TRP15 := #TRP15.EL.StFault;
	    "CONTROLE_STATUS_DB".StFaultGlobal.TRANSPORTADORES.TRP16 := #TRP16.EL.StFault;
	    "CONTROLE_STATUS_DB".StFaultGlobal.TRANSPORTADORES.TRP17 := #TRP17.EL.StFault;
	    "CONTROLE_STATUS_DB".StFaultGlobal.TRANSPORTADORES.TRP18 := #TRP18.EL.StFault;
	    "CONTROLE_STATUS_DB".StFaultGlobal.TRANSPORTADORES.TRP19 := #TRP19.EL.StFault;
	END_REGION
END_FUNCTION_BLOCK

